{
  "function_case": "UPPER",
  "identifier_case": "preserve",
  "quotes": { "strings": "\"", "attributes_with_spaces": "GETVALUE(\"...\")" },
  "spacing": { "comma": "no-space-before", "binary_ops": "space-around" },
  "operators": {
    "logical": {
      "note": "Use symbolic operators only. Word-based operators (AND, OR, NOT) are NOT supported.",
      "and": "&&",
      "or": "||",
      "not": "!"
    }
  }
}